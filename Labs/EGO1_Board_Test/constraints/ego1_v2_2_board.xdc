set_property -dict { PACKAGE_PIN U13 IOSTANDARD LVCMOS33 } [get_ports {sram_dq[13]}]
set_property -dict { PACKAGE_PIN T9  IOSTANDARD LVCMOS33 } [get_ports {sram_dq[14]}]
set_property -dict { PACKAGE_PIN T10 IOSTANDARD LVCMOS33 } [get_ports {sram_dq[15]}]
set_property -dict { PACKAGE_PIN T15 IOSTANDARD LVCMOS33 } [get_ports {sram_addr[0]}]
set_property -dict { PACKAGE_PIN T14 IOSTANDARD LVCMOS33 } [get_ports {sram_addr[1]}]
