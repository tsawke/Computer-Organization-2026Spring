set_property -dict { PACKAGE_PIN U12 IOSTANDARD LVCMOS33 } [get_ports {sram_dq[6]}]
set_property -dict { PACKAGE_PIN V12 IOSTANDARD LVCMOS33 } [get_ports {sram_dq[7]}]
set_property -dict { PACKAGE_PIN V10 IOSTANDARD LVCMOS33 } [get_ports {sram_dq[8]}]
set_property -dict { PACKAGE_PIN V11 IOSTANDARD LVCMOS33 } [get_ports {sram_dq[9]}]
